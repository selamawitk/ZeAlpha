# ============================================
# ZeAlpha Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database (MongoDB Atlas) ---
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/zealpha?retryWrites=true&w=majority

# --- Authentication (JWT) ---
# Use a strong random string (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars

# --- Payment Processing (Stripe) ---
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get webhook secret from Stripe Dashboard > Webhooks > Endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (Nodemailer) ---
# If using Gmail, generate an 'App Password' at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- Frontend URL (CORS) ---
# For production: comma-separate multiple origins (Vercel domain, custom domain)
# Example: https://zealpha.vercel.app,https://yourcustomwedding.com
CLIENT_URL=http://localhost:5173

# --- Google Gemini AI ---
# Free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here